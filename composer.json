{
    "name": "krzar/laravel-translation-generator",
    "description": "Translations generator for laravel apps.",
    "keywords": [
        "laravel",
        "translations",
        "translations-generator"
    ],
    "license": "MIT",
    "version": "v4.0.1",
    "authors": [
        {
            "name": "Krystian Zaręba"
        }
    ],
    "autoload": {
        "psr-4": {
            "Krzar\\LaravelTranslationGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Krzar\\LaravelTranslationGenerator\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.3",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/collections": "^12.0|^13.0",
        "illuminate/container": "^12.0|^13.0",
        "laravel/prompts": "v0.3.15",
        "ext-json": "*"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Krzar\\LaravelTranslationGenerator\\LaravelTranslationGeneratorServiceProvider"
            ]
        }
    },
    "require-dev": {
        "laravel/pint": "^1.4",
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-mockery": "^2.0"
    }
}
